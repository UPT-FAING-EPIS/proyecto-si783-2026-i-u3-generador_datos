{
  "name": "data-generator",
  "displayName": "Data Generator — AI Synthetic Data",
  "publisher": "data-generador",
  "description": "Generate realistic synthetic data for any database using AI",
  "version": "1.0.5",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/data-generator"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Data Science",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dataGenerator.open",
        "title": "Data Generator: Open Panel"
      }
    ],
    "configuration": {
      "title": "Data Generator",
      "properties": {
        "dataGenerator.geminiApiKey": {
          "type": "string",
          "description": "Google Gemini API Key"
        },
        "dataGenerator.locale": {
          "type": "string",
          "default": "es_ES"
        },
        "dataGenerator.defaultSeedSize": {
          "type": "number",
          "default": 8
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build:webview": "vite build",
    "watch:webview": "vite build --watch",
    "package": "npm run build:webview && esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "vscode:package": "vsce package"
  },
  "dependencies": {
    "@faker-js/faker": "^8.4.1",
    "@google/generative-ai": "^0.11.0",
    "lucide-react": "^0.363.0",
    "mongodb": "^6.5.0",
    "mssql": "^10.0.2",
    "mysql2": "^3.9.4",
    "node-sql-parser": "^5.0.0",
    "pg": "^8.11.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/mssql": "^9.1.5",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "@types/react": "^18.2.78",
    "@types/react-dom": "^18.2.25",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vscode/vsce": "^2.24.0",
    "autoprefixer": "^10.4.19",
    "esbuild": "^0.20.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.8"
  }
}
